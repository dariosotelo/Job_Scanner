# Job Scanner — Environment Variables
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env

# ── Telegram Notifications ────────────────────────────────────────────────────
# Required for: node notify-telegram.mjs
#
# Setup (2 minutes):
#   1. Open Telegram and message @BotFather → /newbot → follow prompts
#      Copy the token it gives you → TELEGRAM_BOT_TOKEN
#   2. Send any message to your new bot, then run:
#      curl https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      Find "chat":{"id": XXXXXX} → that number is your TELEGRAM_CHAT_ID

TELEGRAM_BOT_TOKEN=your_bot_token_here

# Personal chat — send notifications only to yourself
# Get your chat ID: send any message to your bot, then run:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
# Find "chat":{"id": XXXXXX}
TELEGRAM_CHAT_ID=your_personal_chat_id_here

# Distribution channel — send to a shared channel (comment out the line above)
# Create a channel, add your bot as admin, forward a message to @userinfobot to get the ID
# Channel IDs start with -100...
# TELEGRAM_CHAT_ID=your_channel_id_here
